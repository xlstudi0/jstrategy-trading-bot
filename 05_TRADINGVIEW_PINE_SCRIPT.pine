// ============================================================
// ESTRATEGIA JORGE — EMA + 12 VELAS + SQUEEZE + ADX + OB
// TradingView Pine Script v5
// DigitalCapitalsTrading — Versión Definitiva
// ============================================================

//@version=6
indicator(title="Estrategia Jorge - EMA + 12 Velas + Squeeze",
          shorttitle="Jorge Strategy",
          overlay=true,
          max_bars_back=500)

// ─── INPUTS ──────────────────────────────────────────────────
grp_ema = "EMAs"
ema10_len   = input.int(10,  "EMA 10 (corto)",  group=grp_ema)
ema55_len   = input.int(55,  "EMA 55 (largo)",  group=grp_ema)
ema200_len  = input.int(200, "EMA 200 (macro)", group=grp_ema)
ema15_len   = input.int(15,  "EMA 15 (estructura)", group=grp_ema)
ema30_len   = input.int(30,  "EMA 30 (estructura)", group=grp_ema)
show_ema200 = input.bool(false, "Mostrar EMA 200", group=grp_ema)
show_ema1530 = input.bool(false, "Mostrar EMA 15/30 (estructura)", group=grp_ema)

grp_sqz = "Squeeze Momentum"
bb_len  = input.int(20,   "BB Length",   group=grp_sqz)
bb_mult = input.float(2.0, "BB Mult",   group=grp_sqz)
kc_len  = input.int(20,   "KC Length",   group=grp_sqz)
kc_mult = input.float(1.5, "KC Mult",   group=grp_sqz)

grp_adx = "ADX"
adx_len = input.int(14, "ADX Período", group=grp_adx)
adx_thr = input.int(21, "ADX umbral tendencia", group=grp_adx)

grp_12c      = "Teoría 12 Velas"
show_count   = input.bool(true, "Mostrar conteo de velas", group=grp_12c)
entry_candle = input.int(7, "Vela de entrada", minval=5, maxval=9, group=grp_12c)

grp_compress = "Compresión"
compress_thr = input.float(2.0, "Umbral compresión (%)",          group=grp_compress)
dist_max     = input.float(3.0, "Distancia máx precio-EMA10 (%)", group=grp_compress)
ema55_prox   = input.float(0.8, "Proximidad a EMA55 (%)",         group=grp_compress)

grp_ob = "Order Blocks"
show_ob = input.bool(true, "Mostrar OB reciente", group=grp_ob)
ob_tol  = input.float(0.8, "Tolerancia OB (%)", group=grp_ob)

grp_sr = "A2 — Soporte / Resistencia"
sr_lookback = input.int(20,  "Lookback S/R (velas)", minval=5, maxval=50, group=grp_sr)
sr_tol      = input.float(1.0, "Tolerancia S/R (%)", minval=0.1, maxval=5.0, group=grp_sr)

grp_poc = "A4 — Liquidez / POC"
poc_lookback = input.int(50,  "Lookback POC (velas)", minval=10, maxval=200, group=grp_poc)
poc_tol      = input.float(1.5, "Tolerancia POC (%)", minval=0.1, maxval=5.0, group=grp_poc)

grp_fvg = "A6 — Imbalance / FVG"
show_fvg    = input.bool(true, "Mostrar FVG en chart", group=grp_fvg)
fvg_lookback = input.int(5,  "Ventana imbalance (velas)", minval=1, maxval=10, group=grp_fvg)

// ─── EMAs ─────────────────────────────────────────────────────
ema10  = ta.ema(close, ema10_len)
ema55  = ta.ema(close, ema55_len)
ema200 = ta.ema(close, ema200_len)
ema15  = ta.ema(close, ema15_len)
ema30  = ta.ema(close, ema30_len)

plot(ema10,  "EMA 10",  color=color.new(color.yellow, 0), linewidth=2)
plot(ema55,  "EMA 55",  color=color.new(color.orange, 0), linewidth=2)
plot(show_ema200  ? ema200 : na, "EMA 200", color=color.new(color.white,  0), linewidth=1)
plot(show_ema1530 ? ema15  : na, "EMA 15",  color=color.new(color.aqua,   30), linewidth=1)
plot(show_ema1530 ? ema30  : na, "EMA 30",  color=color.new(color.purple, 30), linewidth=1)

// ─── TENDENCIA ────────────────────────────────────────────────
bullish_trend = ema10 > ema55
bearish_trend = ema10 < ema55

// Estructura menor (EMA15/30 para confirmar rango vs. cambio de estructura)
struct_bull = ema15 > ema30
struct_bear = ema15 < ema30

bgcolor(bullish_trend ? color.new(color.green, 97) : color.new(color.red, 97),
        title="Fondo tendencia")

// ─── COMPRESIÓN DE EMAs ───────────────────────────────────────
ema_dist_pct  = math.abs(ema10 - ema55) / ema55 * 100
is_compressed = ema_dist_pct < compress_thr
comp_started  = is_compressed and not is_compressed[1]

p1 = plot(ema10, display=display.none)
p2 = plot(ema55, display=display.none)
fill(p1, p2,
     color=is_compressed ? color.new(color.aqua, 75) : color.new(color.gray, 95),
     title="Zona EMA (compresión)")

if comp_started
    label.new(bar_index, high * 1.002, "⚡ COMPRESIÓN",
              color=color.aqua, textcolor=color.black,
              style=label.style_label_down, size=size.small)

// ─── CRUCE DE EMAs ────────────────────────────────────────────
bullish_cross = ta.crossover(ema10, ema55)
bearish_cross = ta.crossunder(ema10, ema55)

plotshape(bullish_cross, "Cruce Alcista", shape.triangleup,
          location.belowbar, color.green, size=size.normal, text="CAMBIO ▲")
plotshape(bearish_cross, "Cruce Bajista", shape.triangledown,
          location.abovebar, color.red,   size=size.normal, text="CAMBIO ▼")

// ─── ADX (Wilder, período 14) ────────────────────────────────
adx_h = high
adx_l = low
adx_c = close

tr_adx   = math.max(adx_h - adx_l, math.abs(adx_h - adx_c[1]), math.abs(adx_l - adx_c[1]))
atr_adx  = ta.rma(tr_adx, adx_len)
dm_plus  = adx_h - adx_h[1] > adx_l[1] - adx_l ? math.max(adx_h - adx_h[1], 0) : 0
dm_minus = adx_l[1] - adx_l > adx_h - adx_h[1] ? math.max(adx_l[1] - adx_l, 0) : 0

di_plus  = 100 * ta.rma(dm_plus,  adx_len) / atr_adx
di_minus = 100 * ta.rma(dm_minus, adx_len) / atr_adx
dx       = 100 * math.abs(di_plus - di_minus) / (di_plus + di_minus)
adx_val  = ta.rma(dx, adx_len)

adx_trend_active = adx_val >= adx_thr
adx_bull = di_plus > di_minus and adx_trend_active
adx_bear = di_minus > di_plus and adx_trend_active

// ─── SQUEEZE MOMENTUM ────────────────────────────────────────
bb_basis = ta.sma(close, bb_len)
bb_dev   = bb_mult * ta.stdev(close, bb_len)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev

tr_val   = math.max(high - low, math.abs(high - close[1]), math.abs(low - close[1]))
kc_basis = ta.ema(close, kc_len)
kc_range = kc_mult * ta.ema(tr_val, kc_len)
kc_upper = kc_basis + kc_range
kc_lower = kc_basis - kc_range

sqz_on  = bb_lower > kc_lower and bb_upper < kc_upper
sqz_off = bb_lower < kc_lower and bb_upper > kc_upper
sqz_just_released = sqz_off and not sqz_off[1]

hh = ta.highest(high, kc_len)
ll = ta.lowest(low,   kc_len)
m  = close - math.avg(math.avg(hh, ll), bb_basis)
momentum_val = ta.linreg(m, kc_len, 0)

sqz_bullish      = momentum_val > 0 and momentum_val > momentum_val[1]
sqz_bearish      = momentum_val < 0 and momentum_val < momentum_val[1]
sqz_fire_bullish = sqz_just_released and momentum_val > 0 and momentum_val > momentum_val[1]
sqz_fire_bearish = sqz_just_released and momentum_val < 0 and momentum_val < momentum_val[1]

// Valle verde toca 0 y no cae → señal de compra
sqz_valley_buy = (momentum_val[1] < 0 and momentum_val[1] > momentum_val[2] and
                  momentum_val > momentum_val[1] and momentum_val < 0.0001 * close)

plotshape(sqz_valley_buy, "Valle Squeeze → Compra", shape.diamond,
          location.belowbar, color.new(color.yellow, 10), size=size.tiny, text="V")

// ─── TEORÍA 12 VELAS ─────────────────────────────────────────
var int candle_count = 0
var int ref_bar      = na

if bullish_cross
    candle_count := 0
    ref_bar      := bar_index

if not na(ref_bar)
    candle_count := bar_index - ref_bar

is_entry_candle = show_count and (candle_count == entry_candle)

plotshape(is_entry_candle, "Vela 7 (Entrada)", shape.circle,
          location.belowbar, color.yellow, size=size.tiny)

if show_count and candle_count > 0 and candle_count <= 14
    label.new(bar_index, low * 0.999,
              str.tostring(candle_count),
              color     = candle_count == 7 ? color.yellow : color.new(color.gray, 50),
              textcolor = color.black,
              style     = label.style_label_up,
              size      = size.tiny)

// ─── CONTEO DE TOQUES EMA55 ───────────────────────────────────
// Cuenta cuántas veces el precio tocó la EMA55 en las últimas 50 velas
ema55_touch_now = math.abs(close - ema55) / ema55 * 100 < ema55_prox
var int touch_count = 0
if ema55_touch_now and not ema55_touch_now[1]
    touch_count += 1

// Resetear conteo al inicio de nueva tendencia
if bullish_cross
    touch_count := 0

// Cuarto toque = señal de LONG directo (resistencia rota)
fourth_touch_long = touch_count >= 4 and ema55_touch_now and bullish_trend

plotshape(fourth_touch_long, "4to Toque EMA55 — LONG", shape.triangleup,
          location.belowbar, color.new(color.fuchsia, 0), size=size.small,
          text="4T\nLONG", textcolor=color.white)

// ─── ORDER BLOCK DETECTION ─────────────────────────────────────
// OB alcista: última vela bajista antes de 3 velas alcistas impulsivas
var float last_bull_ob_high = na
var float last_bull_ob_low  = na
var box   ob_box            = na

bool ob_detected = close[3] < open[3] and close[2] > open[2] and close[1] > open[1] and close > open and close > high[3]

if ob_detected
    last_bull_ob_high := high[3]
    last_bull_ob_low  := low[3]
    if show_ob
        if not na(ob_box)
            box.delete(ob_box)
        ob_box := box.new(bar_index - 3, last_bull_ob_high, bar_index, last_bull_ob_low, bgcolor=color.new(color.teal, 80), border_color=color.new(color.teal, 20), extend=extend.right)

// Precio en zona de OB alcista
price_near_ob = not na(last_bull_ob_low) and close <= last_bull_ob_high * (1 + ob_tol / 100) and close >= last_bull_ob_low * (1 - ob_tol / 100)

// ─── MULTI-TIMEFRAME CONFIRMACIÓN 2H / 3H (intradia) ─────────
// "No te fijes solo en 1H, sino en 2 y 3H — con eso sacas la definición del 4H" — Jorge
ema10_2h = request.security(syminfo.tickerid, "120", ta.ema(close, 10), lookahead=barmerge.lookahead_off)
ema55_2h = request.security(syminfo.tickerid, "120", ta.ema(close, 55), lookahead=barmerge.lookahead_off)
ema10_3h = request.security(syminfo.tickerid, "180", ta.ema(close, 10), lookahead=barmerge.lookahead_off)
ema55_3h = request.security(syminfo.tickerid, "180", ta.ema(close, 55), lookahead=barmerge.lookahead_off)

bull_2h = ema10_2h > ema55_2h
bull_3h = ema10_3h > ema55_3h
mtf_intraday_confirmed = bull_2h and bull_3h  // 2H y 3H alcistas → 4H confirmado sin esperar cierre

// ─── A2 — SOPORTE / RESISTENCIA ──────────────────────────────
// Precio cerca del máximo o mínimo de las últimas sr_lookback velas (nivel de reacción histórica)
key_high_sr = ta.highest(high, sr_lookback)
key_low_sr  = ta.lowest(low,   sr_lookback)
near_sr_high = math.abs(close - key_high_sr) / key_high_sr * 100 < sr_tol
near_sr_low  = math.abs(close - key_low_sr)  / key_low_sr  * 100 < sr_tol
sr_active    = near_sr_high or near_sr_low

// ─── A4 — LIQUIDEZ / POC (Point of Control aproximado) ───────
// Precio del bar con mayor volumen en los últimos poc_lookback bars = POC del perfil de volumen
float poc_price   = close
float poc_max_vol = 0.0
for i = 0 to poc_lookback - 1
    if volume[i] > poc_max_vol
        poc_max_vol := volume[i]
        poc_price   := close[i]
poc_active = math.abs(close - poc_price) / poc_price * 100 < poc_tol

// ─── A6 — IMBALANCE / FVG (Fair Value Gap) ───────────────────
// Imbalance alcista: low actual > high de la vela anterior (hueco sin relleno)
// Imbalance bajista: high actual < low de la vela anterior
fvg_up_now   = low > high[1]
fvg_down_now = high < low[1]

// Detectar FVG activo en ventana reciente
has_fvg_up   = fvg_up_now   or fvg_up_now[1]   or fvg_up_now[2]   or fvg_up_now[3]   or fvg_up_now[4]
has_fvg_down = fvg_down_now or fvg_down_now[1] or fvg_down_now[2] or fvg_down_now[3] or fvg_down_now[4]
has_imbalance = has_fvg_up or has_fvg_down

// Visualizar FVGs en chart
if show_fvg and fvg_up_now
    box.new(bar_index - 1, low, bar_index + 3, high[1],
            bgcolor=color.new(color.green, 85), border_color=color.new(color.green, 40),
            extend=extend.none)
if show_fvg and fvg_down_now
    box.new(bar_index - 1, low[1], bar_index + 3, high,
            bgcolor=color.new(color.red, 85), border_color=color.new(color.red, 40),
            extend=extend.none)

// ─── CONDICIONES AUXILIARES ───────────────────────────────────
price_near_ema55       = math.abs(close - ema55) / ema55 * 100 < ema55_prox
price_not_overextended = math.abs(close - ema10) / ema10 * 100 < dist_max
price_overextended     = not price_not_overextended
vol_ma20               = ta.sma(volume, 20)
vol_above_avg          = volume > vol_ma20 * 1.1
vol_spike              = volume > vol_ma20 * 1.5
upward_without_volume  = close > open and volume < vol_ma20 * 0.8

// Absorción: mecha larga + volumen alto
candle_range  = high - low
body          = math.abs(close - open)
wick_pct      = candle_range > 0 ? (candle_range - body) / candle_range : 0
absorption    = wick_pct > 0.4 and vol_spike

// Volumen de Parada (Stop Candle): primera vela alta-vol después de caída sostenida
// "El volumen de parada lo ven en la primera vela, paso seguido comienza a hacer rango" — Jorge
prev3_all_bearish = close[1] < open[1] and close[2] < open[2] and close[3] < open[3]
stop_candle       = prev3_all_bearish and vol_spike

// ─── SCORE (10 ARGUMENTOS) ───────────────────────────────────
// Réplica del sistema de score del bot Python: mínimo 8/10 para entrar
a1  = mtf_intraday_confirmed
a2  = sr_active
a3  = price_near_ob
a4  = poc_active
a5  = candle_count >= 5 and candle_count <= 8
a6  = has_imbalance
a7  = touch_count >= 3
a8  = vol_spike or absorption or stop_candle
a9  = bullish_trend and is_compressed and price_not_overextended
a10 = mtf_intraday_confirmed and sqz_bullish

score_val = (
    (a1 ? 1 : 0) + (a2 ? 1 : 0) + (a3 ? 1 : 0) + (a4 ? 1 : 0) + (a5 ? 1 : 0) +
    (a6 ? 1 : 0) + (a7 ? 1 : 0) + (a8 ? 1 : 0) + (a9 ? 1 : 0) + (a10 ? 1 : 0)
)

long_by_score      = bullish_trend and score_val >= 8
high_conviction    = bullish_trend and score_val >= 9

// ─── SEÑALES PRINCIPALES ─────────────────────────────────────
// LONG MÁXIMA CONVICCIÓN: requiere compresión, timing, confirmación MTF y soporte cercano.
long_signal = (bullish_trend and is_compressed and is_entry_candle
               and sqz_bullish and price_not_overextended and adx_bull
               and mtf_intraday_confirmed and (price_near_ema55 or price_near_ob))

// LONG ESTÁNDAR: cruce fresco + squeeze liberado + volumen + MTF confirmado
long_signal_alt = (bullish_cross and sqz_fire_bullish and vol_above_avg
                   and price_not_overextended and adx_bull and mtf_intraday_confirmed)

// LONG 4TO TOQUE EMA55
long_fourth_touch = fourth_touch_long and adx_trend_active and mtf_intraday_confirmed and price_near_ema55

// SHORT / COBERTURA: compresión fallida
compression_failed = is_compressed[12] and bearish_trend
short_signal       = bearish_trend and compression_failed and sqz_fire_bearish and adx_bear

// Señal de rebote en EMA55 (zoom temporal)
ema55_rebound = bullish_trend and price_near_ema55 and absorption

// Precio sobreextendido (no entrar)
overextended_warning = price_overextended and bullish_trend and not absorption

// Señal de estructura menor alcista confirmada (EMA15 > EMA30)
struct_confirmed = bullish_trend and struct_bull and sqz_bullish

// Señal Volumen de Parada: posible suelo — recomprar si hay soporte
stop_candle_in_support = stop_candle and (price_near_ema55 or price_near_ob)

// ─── VISUALIZACIÓN SEÑALES ────────────────────────────────────
plotshape(high_conviction, "ALTA CONVICCIÓN (9+/10)", shape.labelup,
          location.belowbar, color.new(color.green, 0),
          size=size.huge, text="🔥LONG\n9+/10", textcolor=color.white)

plotshape(long_by_score and not high_conviction, "LONG SCORE 8/10", shape.labelup,
          location.belowbar, color.new(color.lime, 10),
          size=size.large, text="LONG\n8/10", textcolor=color.black)

plotshape(long_signal, "SEÑAL LONG", shape.labelup,
          location.belowbar, color.new(color.green, 0),
          size=size.large, text="LONG\n✅", textcolor=color.white)

plotshape(long_signal_alt, "SEÑAL LONG ALT", shape.labelup,
          location.belowbar, color.new(color.lime, 20),
          size=size.normal, text="LONG\n🔄", textcolor=color.black)

plotshape(short_signal, "SEÑAL SHORT", shape.labeldown,
          location.abovebar, color.new(color.red, 0),
          size=size.normal, text="SHORT\n⚠️", textcolor=color.white)

// Volumen de Parada en soporte → posible suelo (recomprar 1-2%)
plotshape(stop_candle_in_support, "Vol. Parada en Soporte", shape.diamond,
          location.belowbar, color.new(color.orange, 0),
          size=size.small, text="🛑VOL\nPARADA", textcolor=color.white)

// Volumen de parada genérico (sin soporte exacto — aviso)
plotshape(stop_candle and not stop_candle_in_support, "Vol. Parada", shape.circle,
          location.belowbar, color.new(color.orange, 40),
          size=size.tiny, text="🛑", textcolor=color.white)

plotshape(ema55_rebound, "Rebote EMA55", shape.labelup,
          location.belowbar, color.new(color.purple, 0),
          size=size.small, text="OB55\n↑", textcolor=color.white)

// ─── alertcondition — APARECEN EN "CREAR ALERTA" DE TRADINGVIEW
// Seleccionar "Estrategia Jorge - EMA + 12 Velas + Squeeze" en Condición.

alertcondition(long_signal,
     title  = "🟢 LONG FUERTE — Vela 7 + Compresión + Squeeze + ADX",
     message= "🟢 LONG FUERTE | {{ticker}} {{interval}}\nPrecio: {{close}}\nVela 7 + EMAs comprimidas + Squeeze alcista + ADX con tendencia\nEntrar primer 20% de la posición.")

alertcondition(long_signal_alt,
     title  = "🟡 LONG ALT — Cruce EMA + Squeeze + Volumen + ADX",
     message= "🟡 LONG ALT | {{ticker}} {{interval}}\nPrecio: {{close}}\nCruce EMA10/EMA55 + Squeeze alcista + Volumen alto + ADX tendencia\nEmpieza conteo de 12 velas.")

alertcondition(long_fourth_touch,
     title  = "🔁 LONG 4TO TOQUE — EMA55 ya es soporte",
     message= "🔁 4TO TOQUE EMA55 | {{ticker}} {{interval}}\nPrecio: {{close}}\nLa resistencia EMA55 fue tocada 4 veces — entrada directa LONG\nLa resistencia se convirtió en soporte.")

alertcondition(short_signal,
     title  = "🔴 COBERTURA — Compresión Fallida (abrir SHORT 2x del LONG)",
     message= "🔴 COBERTURA | {{ticker}} {{interval}}\nPrecio: {{close}}\nCompresión fallida (12 velas sin superar resistencia) + ADX bajista\nABRIR SHORT = 2x el margen del LONG activo\nCobrar 80% cuando gana +10%, dejar 20% corriendo")

alertcondition(bullish_cross,
     title  = "🔀 Cambio Estructural ALCISTA — EMA10 cruza EMA55",
     message= "🔀 CAMBIO ESTRUCTURAL ▲ | {{ticker}} {{interval}}\nPrecio: {{close}}\nEMA10 cruzó por encima de EMA55\nInicio conteo de 12 velas — Buscar entrada en vela 7.")

alertcondition(bearish_cross,
     title  = "🔀 Cambio Estructural BAJISTA — EMA10 cruza EMA55",
     message= "🔀 CAMBIO ESTRUCTURAL ▼ | {{ticker}} {{interval}}\nPrecio: {{close}}\nEMA10 cruzó por debajo de EMA55\nTendencia bajista confirmada — Cerrar longs o cubrir.")

alertcondition(comp_started,
     title  = "⚡ Compresión de EMAs Iniciada",
     message= "⚡ COMPRESIÓN DETECTADA | {{ticker}} {{interval}}\nPrecio: {{close}}\nEMA10 y EMA55 se están comprimiendo\nMovimiento fuerte inminente — Preparar entrada en vela 7.")

alertcondition(is_entry_candle,
     title  = "⏰ Vela 7 Alcanzada — Zona de Entrada",
     message= "⏰ VELA 7 | {{ticker}} {{interval}}\nPrecio: {{close}}\nZona óptima de entrada según Teoría 12 Velas\nVerificar: tendencia + squeeze + volumen + ADX antes de entrar.")

alertcondition(price_near_ema55,
     title  = "📍 Precio en EMA55 — Zona de Rebote",
     message= "📍 PRECIO EN EMA55 | {{ticker}} {{interval}}\nPrecio: {{close}}\nEl precio está tocando la EMA55 (soporte dinámico)\nBuscar absorción en velas pequeñas para confirmar rebote.")

alertcondition(overextended_warning,
     title  = "⚠️ Precio Sobreextendido de EMA10 — No Entrar",
     message= "⚠️ SOBREEXTENSIÓN | {{ticker}} {{interval}}\nPrecio: {{close}}\nEl precio se alejó >3% de la EMA10 (1D)\nEsperar corrección hacia EMA10 antes de entrar.")

alertcondition(sqz_bullish,
     title  = "🌀 Squeeze Momentum ALCISTA",
     message= "🌀 SQUEEZE ALCISTA | {{ticker}} {{interval}}\nPrecio: {{close}}\nMomentum positivo y acelerando\nConfirmación alcista adicional.")

alertcondition(sqz_bearish,
     title  = "🌀 Squeeze Momentum BAJISTA",
     message= "🌀 SQUEEZE BAJISTA | {{ticker}} {{interval}}\nPrecio: {{close}}\nMomentum negativo y acelerando\nConfirmación bajista — cuidado con longs abiertos.")

alertcondition(sqz_fire_bullish,
     title  = "🚀 Squeeze DISPARADO ALCISTA",
     message= "🚀 SQUEEZE DISPARADO ALCISTA | {{ticker}} {{interval}}\nPrecio: {{close}}\nSqueeze liberado con momentum positivo — ENTRADA URGENTE LONG")

alertcondition(sqz_fire_bearish,
     title  = "💣 Squeeze DISPARADO BAJISTA",
     message= "💣 SQUEEZE DISPARADO BAJISTA | {{ticker}} {{interval}}\nPrecio: {{close}}\nSqueeze liberado con momentum negativo — CUBRIR URGENTE")

alertcondition(sqz_valley_buy,
     title  = "🟡 Valle Squeeze toca cero — Señal Compra",
     message= "🟡 VALLE SQUEEZE | {{ticker}} {{interval}}\nPrecio: {{close}}\nHistograma verde tocó 0 y rebotó — señal de compra clave\n\"Si el valle verde toca 0 y no cae, es compra\" — Jorge")

alertcondition(ema55_rebound,
     title  = "💜 Rebote EMA55 con Absorción",
     message= "💜 REBOTE EMA55 | {{ticker}} {{interval}}\nPrecio: {{close}}\nPrecio tocando EMA55 + absorción en volumen\nZona de entrada rebote — primer 20%")

alertcondition(price_near_ob,
     title  = "🔲 Precio en Order Block Alcista",
     message= "🔲 ORDER BLOCK ALCISTA | {{ticker}} {{interval}}\nPrecio: {{close}}\nPrecio llegó a zona de OB alcista virgen\nZona de entrada institucional — buscar señal de reversión.")

alertcondition(struct_confirmed,
     title  = "✳️ Estructura Alcista Confirmada — EMA15 > EMA30",
     message= "✳️ ESTRUCTURA ALCISTA | {{ticker}} {{interval}}\nPrecio: {{close}}\nEMA15 > EMA30 + tendencia alcista + Squeeze positivo\nEstructura de menor temporalidad confirmando subida.")

alertcondition(stop_candle_in_support,
     title  = "🛑 Volumen de Parada en Soporte — Posible Suelo",
     message= "🛑 VOLUMEN DE PARADA | {{ticker}} {{interval}}\nPrecio: {{close}}\nPrimera vela con volumen alto post-caída en zona de soporte\nRecomprar 1-2% de la cuenta. \"El volumen de parada lo ven en la primera vela\" — Jorge")

alertcondition(mtf_intraday_confirmed and not mtf_intraday_confirmed[1],
     title  = "📐 2H + 3H Alcistas — 4H Confirmado (Intradia)",
     message= "📐 CONFIRMACIÓN INTRADIA 2H+3H | {{ticker}} {{interval}}\nPrecio: {{close}}\nEMA10 > EMA55 en 2H y 3H simultáneamente\nLa tendencia del 4H está confirmada sin esperar el cierre. Buscar entrada en 1H.")

alertcondition(sr_active,
     title  = "📏 A2 — Precio en Nivel S/R Estructural",
     message= "📏 S/R ESTRUCTURAL | {{ticker}} {{interval}}\nPrecio: {{close}}\nPrecio cerca del máximo/mínimo de las últimas 20 velas\nZona de reacción histórica activa.")

alertcondition(poc_active,
     title  = "💧 A4 — Precio en Zona de Liquidez (POC)",
     message= "💧 LIQUIDEZ / POC | {{ticker}} {{interval}}\nPrecio: {{close}}\nPrecio cerca del Point of Control del perfil de volumen (approx)\nZona de máxima liquidez — reacción probable.")

alertcondition(has_fvg_up and bullish_trend,
     title  = "⬆️ A6 — FVG Alcista Detectado",
     message= "⬆️ FVG ALCISTA | {{ticker}} {{interval}}\nPrecio: {{close}}\nGap de valor justo hacia arriba — precio puede rellenar el imbalance\nConfirmación adicional alcista.")

alertcondition(has_fvg_down and bearish_trend,
     title  = "⬇️ A6 — FVG Bajista Detectado",
     message= "⬇️ FVG BAJISTA | {{ticker}} {{interval}}\nPrecio: {{close}}\nGap de valor justo hacia abajo — posible relleno del imbalance\nAtención con posiciones long.")

alertcondition(high_conviction,
     title  = "🔥 ALTA CONVICCIÓN — Score 9+/10",
     message= "🔥 ALTA CONVICCIÓN | {{ticker}} {{interval}}\nPrecio: {{close}}\nScore 9 o 10 de 10 argumentos activos\nEntrar con tamaño completo según gestión de riesgo.")

alertcondition(long_by_score and not high_conviction,
     title  = "🟢 LONG SCORE — 8/10 Argumentos",
     message= "🟢 LONG SCORE 8/10 | {{ticker}} {{interval}}\nPrecio: {{close}}\n8 de 10 argumentos de la estrategia Jorge activos\nEntrar con tamaño estándar.")

// ─── TABLA DE ESTADO EN PANTALLA ─────────────────────────────
var table info_table = table.new(position.top_right, 4, 19,
                                  border_width=1,
                                  border_color=color.new(color.gray, 50))

if barstate.islast
    // Cabecera
    table.cell(info_table, 0, 0, "INDICADOR",   bgcolor=color.new(color.navy, 0), text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, "VALOR",        bgcolor=color.new(color.navy, 0), text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 0, "REFERENCIA",   bgcolor=color.new(color.navy, 0), text_color=color.white, text_size=size.small)
    table.cell(info_table, 3, 0, "OK?",          bgcolor=color.new(color.navy, 0), text_color=color.white, text_size=size.small)

    // Tendencia
    table.cell(info_table, 0, 1, "Tendencia EMA", text_size=size.small)
    table.cell(info_table, 1, 1, bullish_trend ? "ALCISTA ▲" : "BAJISTA ▼",
               bgcolor=bullish_trend ? color.green : color.red,
               text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 1, "EMA10 vs EMA55", text_size=size.small)
    table.cell(info_table, 3, 1, bullish_trend ? "✅" : "❌", text_size=size.small)

    // Estructura menor
    table.cell(info_table, 0, 2, "Estructura EMA15/30", text_size=size.small)
    table.cell(info_table, 1, 2, struct_bull ? "ALCISTA ▲" : "BAJISTA ▼",
               bgcolor=struct_bull ? color.new(color.green, 40) : color.new(color.red, 40),
               text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 2, "EMA15 vs EMA30", text_size=size.small)
    table.cell(info_table, 3, 2, struct_bull ? "✅" : "❌", text_size=size.small)

    // ADX
    table.cell(info_table, 0, 3, "ADX", text_size=size.small)
    table.cell(info_table, 1, 3,
               str.tostring(math.round(adx_val, 1)) + " | " + (adx_bull ? "BULL" : adx_bear ? "BEAR" : "Rango"),
               bgcolor=adx_bull ? color.new(color.green, 50) : adx_bear ? color.new(color.red, 50) : color.new(color.gray, 60),
               text_size=size.small)
    table.cell(info_table, 2, 3, "≥ " + str.tostring(adx_thr) + " = tendencia", text_size=size.small)
    table.cell(info_table, 3, 3, adx_bull ? "✅" : (adx_bear ? "🔴" : "⬜"), text_size=size.small)

    // Compresión
    table.cell(info_table, 0, 4, "Compresión EMAs", text_size=size.small)
    table.cell(info_table, 1, 4,
               is_compressed ? "⚡ COMPRIMIDAS" : str.tostring(math.round(ema_dist_pct, 2)) + "%",
               bgcolor=is_compressed ? color.new(color.aqua, 0) : color.new(color.gray, 50),
               text_size=size.small)
    table.cell(info_table, 2, 4, "< " + str.tostring(compress_thr) + "%", text_size=size.small)
    table.cell(info_table, 3, 4, is_compressed ? "✅" : "⬜", text_size=size.small)

    // Vela 12
    candle_ok = candle_count >= 5 and candle_count <= 8
    table.cell(info_table, 0, 5, "Teoría 12 Velas", text_size=size.small)
    table.cell(info_table, 1, 5,
               candle_count > 0 ? "Vela " + str.tostring(candle_count) : "Sin conteo",
               bgcolor=candle_ok ? color.new(color.yellow, 30) : color.new(color.gray, 80),
               text_size=size.small)
    table.cell(info_table, 2, 5, "Zona 5-8", text_size=size.small)
    table.cell(info_table, 3, 5, candle_ok ? "✅" : "⬜", text_size=size.small)

    // Squeeze
    table.cell(info_table, 0, 6, "Squeeze", text_size=size.small)
    sqz_state = sqz_fire_bullish ? "🚀 DISPARADO" : sqz_on ? "🔒 ON" : sqz_off ? "🔓 OFF" : "➖"
    table.cell(info_table, 1, 6,
               sqz_bullish ? "ALCISTA ▲ " + sqz_state : (sqz_bearish ? "BAJISTA ▼ " + sqz_state : sqz_state),
               bgcolor=sqz_bullish ? color.green : (sqz_bearish ? color.red : color.gray),
               text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 6, "Histograma +", text_size=size.small)
    table.cell(info_table, 3, 6, sqz_bullish ? "✅" : "❌", text_size=size.small)

    // Distancia EMA10
    table.cell(info_table, 0, 7, "Dist. Precio-EMA10", text_size=size.small)
    dist_val = math.abs(close - ema10) / ema10 * 100
    table.cell(info_table, 1, 7,
               str.tostring(math.round(dist_val, 2)) + "%",
               bgcolor=dist_val > dist_max ? color.new(color.red, 40) : color.new(color.gray, 70),
               text_size=size.small)
    table.cell(info_table, 2, 7, "< " + str.tostring(dist_max) + "%", text_size=size.small)
    table.cell(info_table, 3, 7, price_not_overextended ? "✅" : "❌", text_size=size.small)

    // Volumen
    table.cell(info_table, 0, 8, "Volumen", text_size=size.small)
    table.cell(info_table, 1, 8,
               vol_spike ? "🔥 ALTO" : (vol_above_avg ? "NORMAL+" : upward_without_volume ? "⚠️ TRAMPA" : "BAJO"),
               bgcolor=vol_spike ? color.new(color.green, 30) : upward_without_volume ? color.new(color.red, 40) : color.new(color.gray, 70),
               text_size=size.small)
    table.cell(info_table, 2, 8, "> 1.5× MA(20)", text_size=size.small)
    table.cell(info_table, 3, 8, vol_above_avg ? "✅" : "⬜", text_size=size.small)

    // Toque EMA55
    table.cell(info_table, 0, 9, "Toques EMA55", text_size=size.small)
    table.cell(info_table, 1, 9,
               str.tostring(touch_count) + " toque" + (touch_count != 1 ? "s" : ""),
               bgcolor=touch_count >= 4 ? color.new(color.fuchsia, 20) : touch_count >= 3 ? color.new(color.orange, 40) : color.new(color.gray, 70),
               text_size=size.small)
    table.cell(info_table, 2, 9, "4to = LONG directo", text_size=size.small)
    table.cell(info_table, 3, 9, touch_count >= 4 ? "🔁" : (touch_count >= 3 ? "⚡" : "⬜"), text_size=size.small)

    // OB
    table.cell(info_table, 0, 10, "Order Block", text_size=size.small)
    table.cell(info_table, 1, 10,
               price_near_ob ? "🔲 EN ZONA OB" : (not na(last_bull_ob_low) ? str.tostring(math.round(last_bull_ob_low, 1)) + "/" + str.tostring(math.round(last_bull_ob_high, 1)) : "Sin OB"),
               bgcolor=price_near_ob ? color.new(color.teal, 20) : color.new(color.gray, 70),
               text_size=size.small)
    table.cell(info_table, 2, 10, "Zona virgen 4H+", text_size=size.small)
    table.cell(info_table, 3, 10, price_near_ob ? "✅" : "⬜", text_size=size.small)

    // 2H + 3H Intradia
    table.cell(info_table, 0, 11, "2H + 3H (Intradia)", text_size=size.small)
    mtf_str = bull_2h and bull_3h ? "✅ 2H + 3H ALCISTAS" :
              bull_2h             ? "2H ▲  3H ▼" :
              bull_3h             ? "2H ▼  3H ▲" : "❌ AMBOS BAJISTAS"
    table.cell(info_table, 1, 11, mtf_str,
               bgcolor=mtf_intraday_confirmed ? color.new(color.green, 30) : color.new(color.red, 60),
               text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 11, "Definen el 4H", text_size=size.small)
    table.cell(info_table, 3, 11, mtf_intraday_confirmed ? "✅" : "❌", text_size=size.small)

    // Volumen de Parada
    table.cell(info_table, 0, 12, "Vol. Parada", text_size=size.small)
    table.cell(info_table, 1, 12,
               stop_candle_in_support ? "🛑 EN SOPORTE" : stop_candle ? "🛑 DETECTADO" : "—",
               bgcolor=stop_candle_in_support ? color.new(color.orange, 0) : stop_candle ? color.new(color.orange, 50) : color.new(color.gray, 80),
               text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 12, "Recomprar 1-2%", text_size=size.small)
    table.cell(info_table, 3, 12, stop_candle_in_support ? "🛑" : "⬜", text_size=size.small)

    // A2 — Soporte / Resistencia
    table.cell(info_table, 0, 13, "A2 S/R Estructural", text_size=size.small)
    sr_str = near_sr_high ? "🔴 CERCA RESISTENCIA" : near_sr_low ? "🟢 CERCA SOPORTE" : "—"
    table.cell(info_table, 1, 13, sr_str,
               bgcolor=sr_active ? color.new(color.teal, 30) : color.new(color.gray, 80),
               text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 13, "Max/Min " + str.tostring(sr_lookback) + " velas ±" + str.tostring(sr_tol) + "%", text_size=size.small)
    table.cell(info_table, 3, 13, sr_active ? "✅" : "⬜", text_size=size.small)

    // A4 — Liquidez / POC
    table.cell(info_table, 0, 14, "A4 Liquidez / POC", text_size=size.small)
    table.cell(info_table, 1, 14,
               poc_active ? "💧 EN ZONA POC" : str.tostring(math.round(poc_price, 1)),
               bgcolor=poc_active ? color.new(color.blue, 30) : color.new(color.gray, 80),
               text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 14, "Vol máx " + str.tostring(poc_lookback) + " velas ±" + str.tostring(poc_tol) + "%", text_size=size.small)
    table.cell(info_table, 3, 14, poc_active ? "✅" : "⬜", text_size=size.small)

    // A6 — Imbalance / FVG
    table.cell(info_table, 0, 15, "A6 Imbalance/FVG", text_size=size.small)
    fvg_str = has_fvg_up and has_fvg_down ? "⬆️⬇️ AMBOS" : has_fvg_up ? "⬆️ FVG ALCISTA" : has_fvg_down ? "⬇️ FVG BAJISTA" : "—"
    table.cell(info_table, 1, 15, fvg_str,
               bgcolor=has_imbalance ? color.new(color.yellow, 30) : color.new(color.gray, 80),
               text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 15, "FVG últimas " + str.tostring(fvg_lookback) + " velas", text_size=size.small)
    table.cell(info_table, 3, 15, has_imbalance ? "✅" : "⬜", text_size=size.small)

    // Score total
    score_col = (score_val >= 9 ? color.new(color.green,  10) :
                 score_val >= 8 ? color.new(color.lime,   30) :
                 score_val >= 6 ? color.new(color.orange, 30) : color.new(color.red, 40))
    table.cell(info_table, 0, 16, "SCORE (bot)", text_size=size.small,
               bgcolor=color.new(color.navy, 20), text_color=color.white)
    table.merge_cells(info_table, 1, 16, 3, 16)
    table.cell(info_table, 1, 16,
               str.tostring(score_val) + "/10" + (score_val >= 9 ? "  🔥 ALTA CONVICCIÓN" : score_val >= 8 ? "  ✅ ENTRAR" : "  ⏳ ESPERAR"),
               bgcolor=score_col, text_color=color.white, text_size=size.normal)

    // Horizonte de holding
    tf_horizon = timeframe.period == "15"  ? "~3 horas"   :
                 timeframe.period == "30"  ? "~6 horas"   :
                 timeframe.period == "60"  ? "8-12 horas" :
                 timeframe.period == "120" ? "~24 horas"  :
                 timeframe.period == "240" ? "~72 horas"  :
                 timeframe.period == "D"   ? "~12 días"   : "variable"
    table.cell(info_table, 0, 17, "Horizonte hold", text_size=size.small)
    table.cell(info_table, 1, 17, tf_horizon,
               bgcolor=color.new(color.navy, 40), text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 17, "No cerrar antes", text_size=size.small)
    table.cell(info_table, 3, 17, "⏱", text_size=size.small)

    // Señal final
    final_str = (high_conviction         ? "🔥 ALTA CONVICCIÓN (" + str.tostring(score_val) + "/10)" :
                 long_by_score           ? "🟢 LONG — SCORE " + str.tostring(score_val) + "/10"      :
                 long_signal             ? "🟢 LONG FUERTE"       :
                 long_fourth_touch       ? "🔁 LONG 4TO TOQUE"    :
                 long_signal_alt         ? "🟡 LONG ALT"           :
                 ema55_rebound           ? "💜 REBOTE EMA55"       :
                 stop_candle_in_support  ? "🛑 VOL PARADA — DCA"  :
                 short_signal            ? "🔴 SHORT/COBERTURA"    :
                 sqz_fire_bullish        ? "🚀 SQUEEZE FIRE"       : "⬜ ESPERAR")
    final_col = (high_conviction         ? color.new(color.green,   0) :
                 long_by_score           ? color.new(color.lime,   10) :
                 long_signal             ? color.new(color.green,   0) :
                 long_fourth_touch       ? color.new(color.fuchsia, 0) :
                 long_signal_alt         ? color.new(color.yellow,  0) :
                 ema55_rebound           ? color.new(color.purple,  0) :
                 stop_candle_in_support  ? color.new(color.orange,  0) :
                 short_signal            ? color.new(color.red,     0) :
                 sqz_fire_bullish        ? color.new(color.lime,    0) :
                                           color.new(color.gray,   50))
    table.cell(info_table, 0, 18, "SEÑAL FINAL",
               bgcolor=color.new(color.navy, 20), text_color=color.white, text_size=size.small)
    table.merge_cells(info_table, 1, 18, 3, 18)
    table.cell(info_table, 1, 18, final_str,
               bgcolor=final_col, text_color=color.white, text_size=size.normal)
